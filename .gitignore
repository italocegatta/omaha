# Project: keep data/ tracked. Ignore only generated DB artifacts.
# The CSV seed triplet under data/seed/ is source of truth for the
# CSV-driven seed (`scripts/seed_from_csv.py`).
data/*.db
data/snapshots/

# OpenSpec roadmap ephemeral working artifacts (audit notes, scratch
# checklists). The canonical register lives at openspec/roadmap.md;
# anything under `.temp_assets/` is throwaway support state and must
# not be committed.
openspec/.temp_assets/

# S06 production deploy artifacts.
# - backups/ holds SQLite snapshots produced by the 'backup' service in
#   prod.yml; the directory is bind-mounted in, the .db files are
#   generated.
# - certs/ holds the TLS cert chain (fullchain.pem + privkey.pem) that
#   nginx serves. The .gitkeep keeps the directory tracked.
#   certs/webroot/ is the ACME http-01 challenge webroot: the certbot
#   sidecar (prod.yml certbot service) writes challenge tokens here
#   and nginx serves them on port 80. Only the directory + .gitkeep
#   are tracked; the challenge tokens themselves are ephemeral.
# - nginx/ holds the nginx.conf that gets bind-mounted into the nginx
#   container. The .gitkeep is defensive: the actual conf is committed
#   alongside, but if someone deletes it locally the .gitkeep stops
#   `docker compose -f prod.yml up` from silently mounting an empty
#   directory.
backups/*
!backups/.gitkeep
certs/*
!certs/.gitkeep
!certs/webroot/
!certs/webroot/.gitkeep
nginx/*
!nginx/.gitkeep
!nginx/nginx.conf
.coverage

# Mutation testing — mutmut cache + per-run JSON outputs. Cache is
# recreated by `task mutation`; no `.gitkeep` needed (existence is
# a side-effect of the first run). See
# `openspec/specs/rebalance-mutation-testing/spec.md`.
mutants/

# Visual regression generated artifacts. Baseline PNGs under
# tests/visual/baselines/ are source artifacts and stay tracked.
tests/visual/results/
tests/visual/diffs/
tests/visual/test-results/
tests/visual/**/*.actual.png
tests/visual/**/*.diff.png
!tests/visual/baselines/
!tests/visual/baselines/**/*.png
!tests/visual/baselines/.gitkeep
