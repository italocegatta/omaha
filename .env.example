# Copy to `.env` and fill in real values. Never commit `.env`.

# 50+ char random string used to sign session cookies.
# Generate: `python -c "import secrets; print(secrets.token_urlsafe(50))"`
SECRET_KEY=change-me-to-a-random-50-char-string

# Shared family password gating the login page.
# Canonical default for Italo + Ana profiles: `distendidos`.
# DO NOT change without explicit owner sign-off — see AGENTS.md "Family password".
ADMIN_PASSWORD=distendidos

# SQLite database file. Path is relative to the working directory.
DATABASE_URL=sqlite:///./data/portfolio.db

# Quote cache TTL (seconds). Default 900 (15 minutes).
QUOTE_TTL_SECONDS=900
# Background quote refresh interval (seconds). Default 900 (15 minutes).
QUOTE_REFRESH_INTERVAL_SECONDS=900
# Circuit breaker cooldown after consecutive full-batch failures (seconds).
QUOTE_REFRESH_CIRCUIT_COOLDOWN_SECONDS=300
# Consecutive full-batch failures before opening the circuit breaker.
QUOTE_REFRESH_CIRCUIT_THRESHOLD=3
